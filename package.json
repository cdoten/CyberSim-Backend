{
  "name": "cybersim-api",
  "version": "1.1.0",
  "description": "",
  "main": "index.js",
  "author": "Rolan Szoke (fwalkwithm@gmail.com)",
  "license": "ISC",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "LOG_LEVEL=info nodemon --watch .env -r dotenv/config index.js",
    "start": "node -r dotenv/config index.js",
    "start:prod": "NODE_ENV=production node -r dotenv/config index.js",
    "lint": "eslint .",
    "smoke": "bash scripts/smoke.sh",
    "test": "cross-env DOTENV_CONFIG_PATH=.env.test node -r dotenv/config ./node_modules/.bin/jest --runInBand",
    "migrate": "knex migrate:latest",
    "rollback": "knex migrate:rollback",
    "reset:migrations": "knex migrate:rollback --all && knex migrate:latest",
    "seed": "knex seed:run",
    "seed:dataset": "knex seed:run --specific loaders/dataset_seed.js",
    "reset-db": "npm run reset:migrations && npm run seed",
    "reset-db:dataset": "npm run reset:migrations && npm run seed:dataset",
    "dataset:export": "node -r dotenv/config scripts/exportDatasetFromAirtable.js",
    "build-deploy": "zip -r deploy.zip . -x \"node_modules/*\" -x \"*.env*\" -x \".git/*\" -x \"*.zip\" -x \".vscode/*\""
  },
  "dependencies": {
    "@types/jest": "^26.0.8",
    "airtable": "^0.11.2",
    "body-parser": "^1.19.2",
    "cors": "^2.8.6",
    "dotenv": "8.2.0",
    "express": "^4.17.1",
    "express-pino-logger": "5.0.0",
    "helmet": "4.0.0",
    "knex": "^0.21.2",
    "pg": "^8.3.0",
    "pino": "6.5.0",
    "socket.io": "^4.5.0",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jest": "^23.20.0",
    "eslint-plugin-prettier": "^3.1.4",
    "husky": "^4.2.5",
    "jest": "26.2.2",
    "nodemon": "2.0.4",
    "pino-pretty": "^4.8.0",
    "prettier": "^2.0.5",
    "supertest": "4.0.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "pre-push": "npm run test"
    }
  }
}